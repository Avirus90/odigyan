rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function appConfig() {
      return get(/databases/$(database)/documents/config/app);
    }

    function isAdmin() {
      return isSignedIn() && request.auth.uid in appConfig().data.adminUids;
    }

    function hasOnlyStudentWritableFields() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        'name', 'dob', 'phone', 'email', 'updatedAt'
      ]);
    }

    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /uidMap/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if false;
    }

    match /students/{studentDocId} {
      allow read: if isAdmin() || (
        isSignedIn() &&
        exists(/databases/$(database)/documents/uidMap/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/uidMap/$(request.auth.uid)).data.studentDocId == studentDocId
      );

      allow create: if false;

      allow update: if isAdmin() || (
        isSignedIn() &&
        exists(/databases/$(database)/documents/uidMap/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/uidMap/$(request.auth.uid)).data.studentDocId == studentDocId &&
        hasOnlyStudentWritableFields()
      );

      allow delete: if isAdmin();
    }

    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();

      match /sections/{sectionId} {
        allow read: if true;
        allow write: if isAdmin();

        match /folders/{folderId} {
          allow read: if true;
          allow write: if isAdmin();

          match /items/{itemId} {
            allow read: if true;
            allow write: if isAdmin();
          }
        }
      }
    }

    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /currentAffairs/{articleId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
